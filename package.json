  },
  "homepage": "https://github.com/gauthier-th/divia-api#readme",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^4.9.5",
    "vite": "^8.0.1",
    "vite-plugin-dts": "^4.5.4"
  }
